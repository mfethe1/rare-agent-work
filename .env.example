# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_from_stripe_dashboard_or_cli
STRIPE_PRICE_ID=price_from_stripe_product

# Google Ads / gtag
NEXT_PUBLIC_GOOGLE_ADS_TAG_ID=AW-XXXXXXXXXX

# Paid Guide Chat (locked by default)
GUIDE_CHAT_ENABLED=false
GUIDE_ACCESS_KEY=replace_with_server_side_secret
GUIDE_BASE_COST_PER_1K_USD=0.015
GUIDE_MODEL=anthropic/claude-sonnet-4-6

# Job Queue (Upstash Redis + BullMQ)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
REDIS_URL=redis://default:password@your-redis.upstash.io:6379
USE_JOB_QUEUE=true
WORKER_CONCURRENCY=5
WORKER_MAX_JOBS_PER_SECOND=10

# Service API Key (for /api/jobs endpoints)
SERVICE_API_KEY=your-secret-service-key
